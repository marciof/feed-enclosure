#!/bin/sh

# Runs a command for each URL argument.
# Arguments: [URL ...]

# FIXME document (including dependencies and setup)
# FIXME test (including shellcheck)
# FIXME error handling
# FIXME proper logging (including to syslog)
# TODO check https://github.com/TheFrenchGhosty/TheFrenchGhostys-Ultimate-YouTube-DL-Scripts-Collection

set -e -u

# Arguments: see `curl`
# Returns: success
curl_dry_run() {
    # FIXME confirm this is ok, see https://github.com/curl/curl/issues/5426
    curl --resolve '*:80:127.0.0.1' --resolve '*:443:127.0.0.1' "$@" || true
}

# Arguments: see `curl`
# Stdout: URL encoded part of the query string
curl_encode_query_string() {
    # FIXME use Python instead? or is curl more widely available?
    curl_dry_run --silent --get --write-out '%{url.query}' "$@" -- _
}

# See https://github.com/vanloctech/youwee/blob/main/docs/browser-extension.md#how-it-works
# See https://github.com/vanloctech/youwee/tree/main/extensions/youwee-webext
# See buildDeepLink(): https://raw.githubusercontent.com/vanloctech/youwee/main/extensions/youwee-webext/src/shared.js#:~:text=function%20buildDeepLink
# See normalizeQuality(): https://raw.githubusercontent.com/vanloctech/youwee/main/extensions/youwee-webext/src/shared.js#:~:text=function%20normalizeQuality
#
# Arguments: URL [quality | '']
# Stdout: youwee:// protocol encoded download URL in one line
encode_youwee_download_url() {
    # FIXME option to use other video formats (eg. mp4 doesn't embed metadata)
    # FIXME embed subtitles
    printf 'youwee://download?v=1&action=download_now&%s\n' \
        "$(curl_encode_query_string \
            --data-urlencode "url=$1" \
            --data-urlencode "quality=${2:-}")"
}

# See https://youwee.app
#
# Arguments: see `encode_youwee_download_url`
download_url_with_youwee() {
    # FIXME document how to register protocol handling
    #   $ ln -s ext_cmd/Youwee.desktop ~/.local/share/applications/
    #   $ update-desktop-database ~/.local/share/applications
    #   $ apt install qttools5-dev-tools
    #   $ xdg-mime default Youwee.desktop x-scheme-handler/youwee
    # FIXME command line option? https://github.com/vanloctech/youwee/issues/76
    # FIXME disable window focus (workaround w/ KWin scripting API & D-Bus?)
    xdg-open "$(encode_youwee_download_url "$@")"
}

# See https://github.com/mhogomchungu/media-downloader
#
# Arguments: URL
download_url_with_media_downloader() {
    flatpak run io.github.mhogomchungu.media-downloader -a -u "$1"
}

# Arguments: URL
is_live_stream() {
    # FIXME too slow, and maybe at this point all these GUIs aren't worth it
    # FIXME multiple dependencies on yt-dlp
    yt-dlp \
        --quiet \
        --simulate \
        --match-filter '!is_live & !was_live' \
        --exec 'after_filter:exit 1' \
        "$1" 2>/dev/null
}

for url; do
    notify-send 'Enclosure URL' "$url"

    if is_live_stream "$url"; then
        echo "Livestream skipped: $url" >&2
    else
        download_url_with_youwee "$url" 720
        # download_url_with_media_downloader "$url"
    fi
done
